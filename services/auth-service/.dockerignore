.vscode/
.idea/
*.swp
*.swo

# Archivos de Alembic (opcional, se ejecutan en el contenedor)
alembic/versions/*.pyc

# Archivos de prueba
tests/
.pytest_cache/
.coverage

# Archivos de git
.git/
.gitignore

# Documentación
README.md
LICENSE

# Logs
*.log