venv/
env/
.venv/

# Archivos de Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Base de datos local (no copiar al contenedor)
*.db
*.sqlite
*.sqlite3

# Archivos de entorno
.env
.env.local
