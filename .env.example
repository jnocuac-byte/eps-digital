# ============================================
# EPS Digital - Entorno Local Docker
# ============================================
# Copiar este archivo a .env antes de iniciar
# cp .env.example .env
# ============================================

# JWT Secret (usar una clave larga y aleatoria)
JWT_SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars

# --- Service URLs (para comunicacion interna entre servicios) ---
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
CITAS_SERVICE_URL=http://citas-service:8003
CATALOG_SERVICE_URL=http://catalog-service:8004
AI_NLP_SERVICE_URL=http://ainlp-service:8005

# --- External Service URLs (para el frontend) ---
VITE_AUTH_URL=http://localhost:8001
VITE_USER_URL=http://localhost:8002
VITE_CITAS_URL=http://localhost:8003
VITE_CATALOGO_URL=http://localhost:8004
VITE_AI_URL=http://localhost:8005
VITE_NOTIFICACIONES_URL=http://localhost:8006

# --- AI/NLP Service ---
# Requiere clave de Groq API (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# --- Notifications Service ---
# Opcional - SendGrid para envio de emails
# Si no se configura, el servicio solo hara logging
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@epsdigital.com

# --- RabbitMQ ---
# Para desarrollo local (guest/guest)
# Production: cambiar credenciales
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672